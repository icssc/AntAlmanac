{
    "compilerOptions": {
        "target": "esnext",
        "module": "esnext",
        "moduleResolution": "bundler",
        "esModuleInterop": true,
        "experimentalDecorators": true,
        "strict": true,
        "skipLibCheck": true,
        "baseUrl": ".",
        "paths": {
            "$types/*": ["src/types/*"],
            "$utils/*": ["src/utils/*"],
            "$client/*": ["src/client/*"]
        },
        "rootDir": "src",
        "outDir": "dist"
    },
    "include": ["src/**/*"]
}
