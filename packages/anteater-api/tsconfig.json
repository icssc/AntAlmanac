{
    "compilerOptions": {
        "target": "esnext",
        "module": "esnext",
        "moduleResolution": "bundler",
        "esModuleInterop": true,
        "experimentalDecorators": true,
        "strict": true,
        "skipLibCheck": true,
        "baseUrl": ".",
        "paths": {
            "@packages/anteater-api/types": ["./src/types/index.ts"],
            "@packages/anteater-api/client": ["./src/client/index.ts"],
            "@packages/anteater-api/utils": ["./src/utils/index.ts"]
        },
        "rootDir": "src",
        "outDir": "dist"
    },
    "include": ["src/**/*"]
}
