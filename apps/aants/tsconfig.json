{
    "compilerOptions": {
        "target": "esnext",
        "module": "esnext",
        "moduleResolution": "bundler",
        "esModuleInterop": true,
        "strict": true,
        "skipLibCheck": true,
        "baseUrl": ".",
        "outDir": "dist",
        "resolveJsonModule": true,
        "jsx": "react-jsx"
    },
    "include": ["src/**/*", "scripts"],
    "exclude": ["node_modules", "dist"]
}
