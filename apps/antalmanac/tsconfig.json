{
    "extends": ["@total-typescript/tsconfig/bundler/dom", "../../tsconfig.base.json"],
    "compilerOptions": {
        "lib": ["es2024", "esnext.collection", "dom", "dom.iterable"],
        "jsx": "react-jsx",
        "plugins": [
            {
                "name": "next"
            }
        ],
        "baseUrl": ".",
        "paths": {
            "$actions/*": ["src/actions/*"],
            "$api/*": ["src/api/*"],
            "$backend/*": ["src/backend/*"],
            "$components/*": ["src/components/*"],
            "$generated/*": ["src/generated/*"],
            "$lib/*": ["src/lib/*"],
            "$hooks/*": ["src/hooks/*"],
            "$providers/*": ["src/providers/*"],
            "$routes/*": ["src/routes/*"],
            "$stores/*": ["src/stores/*"],
            "$src/*": ["src/*"],
            "$scripts/*": ["scripts/*"]
        }
    },
    "include": ["./dist/types/**/*.ts", "./next-env.d.ts", "./src", ".next/types/**/*.ts", ".next/dev/types/**/*.ts", "./scripts"],
    "exclude": ["./node_modules"]
}
