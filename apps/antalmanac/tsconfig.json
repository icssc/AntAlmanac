{
    "extends": ["@total-typescript/tsconfig/bundler/dom", "../../tsconfig.base.json"],
    "compilerOptions": {
        "lib": ["es2024", "esnext.collection", "dom", "dom.iterable"],
        "jsx": "react-jsx",
        "plugins": [
            {
                "name": "next"
            }
        ],
        "baseUrl": ".",
        "paths": {
            "$actions/*": ["src/actions/*"],
            "$backend/*": ["src/backend/*"],
            "$components/*": ["src/components/*"],
            "$generated/*": ["src/generated/*"],
            "$lib/*": ["src/lib/*"],
            "$hooks/*": ["src/hooks/*"],
            "$planner/*": ["src/planner/*"],
            "$plannerApp/*": ["src/app/planner/*"],
            "$providers/*": ["src/providers/*"],
            "$stores/*": ["src/stores/*"],
            "$src/*": ["src/*"],
            "$scripts/*": ["scripts/*"]
        }
    },
    "include": [
        "./dist/types/**/*.ts",
        "./next-env.d.ts",
        "./src",
        "./tests",
        ".next/types/**/*.ts",
        ".next/dev/types/**/*.ts",
        "./scripts"
    ],
    "exclude": ["./node_modules"]
}
