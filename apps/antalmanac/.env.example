# SST stage name locally (production on deploy). Used for notification subscriptions.
STAGE=local

# Postgres (also used by @packages/db migrations via packages/db/.env)
DB_URL="postgres://postgres:postgres@localhost:5432/antalmanac"

# Anteater API (scripts + backend)
ANTEATER_API_KEY=

# Mapbox proxy routes (optional locally if not using the map)
MAPBOX_ACCESS_TOKEN=

# PeterPortal planner roadmaps (optional locally)
PLANNER_CLIENT_API_KEY=

# ICSSC auth / Better Auth
OIDC_CLIENT_ID=antalmanac-dev
OIDC_ISSUER_URL=https://auth.icssc.club
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=

# Client (optional)
NEXT_PUBLIC_TILES_ENDPOINT=
NEXT_PUBLIC_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_PUBLIC_POSTHOG_HOST=
# NEXT_PUBLIC_ENDPOINT=staging-1234
# NEXT_PUBLIC_LOCAL_SERVER=true
