STAGE=local
MAPBOX_ACCESS_TOKEN=
ANTEATER_API_KEY=
DB_URL="postgres://postgres:postgres@localhost:5432/antalmanac"
OIDC_CLIENT_ID=antalmanac-dev
OIDC_ISSUER_URL=https://auth.icssc.club
GOOGLE_REDIRECT_URI=http://localhost:3000/auth

# Apple App Site Association (AASA) — consumed by
# apps/antalmanac/src/app/apple-app-site-association/route.ts to emit
# /.well-known/apple-app-site-association for Universal Links + passkey
# web credentials. Leave blank in dev; set in prod/staging once the iOS
# app is provisioned.
# APPLE_TEAM_ID=                        # 10-char Apple Developer Team ID
# APPLE_BUNDLE_IDS=                     # comma-separated, e.g. "com.icssc.antalmanac,com.antalmanac.testflight1127"
