<?xml version="1.0" encoding="utf-8"?>
<!--
  The activity uses Theme.AntAlmanac.Starting between cold launch and the
  first Chrome paint, then androidbrowserhelper swaps the splash drawable
  out. The theme is intentionally bare — no toolbar, no action bar — to
  avoid a frame of Android system chrome before Chrome takes over.
-->
<resources>
    <style name="Theme.AntAlmanac.Starting" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowBackground">@color/backgroundColor</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:statusBarColor">@color/colorPrimaryDark</item>
        <item name="android:navigationBarColor">@color/navigationColor</item>
    </style>
</resources>
