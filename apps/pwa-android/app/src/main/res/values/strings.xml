<?xml version="1.0" encoding="utf-8"?>
<!--
  The bool here gates the notification DelegationService in
  AndroidManifest.xml. Disabling it (`false`) removes the service entirely
  from the merged manifest — same effect as
  twa-manifest.json `enableNotifications: false`.
-->
<resources>
    <string name="app_name">AntAlmanac</string>
    <bool name="enableNotification">true</bool>
    <integer name="splashScreenFadeOutDuration">300</integer>
</resources>
