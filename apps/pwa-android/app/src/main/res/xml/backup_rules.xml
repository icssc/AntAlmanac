<?xml version="1.0" encoding="utf-8"?>
<!--
  Backup config for Auto Backup. Mirrors iOS's default behaviour of
  backing up `Documents/` to iCloud unless explicitly excluded.

  Schedules are stored server-side keyed off the user account, so there's
  nothing user-visible to back up locally. We exclude the WebView cookies
  and the WebView cache so a restored device doesn't carry over a stale
  session token.
-->
<full-backup-content>
    <exclude domain="database" path="webview" />
    <exclude domain="database" path="webviewCookiesChromium.db" />
    <exclude domain="database" path="webviewCookiesChromiumPrivate.db" />
    <exclude domain="file" path="webview" />
</full-backup-content>
