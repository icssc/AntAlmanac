<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ replacement for backup_rules.xml. Same exclusions; both must
  exist for the manifest to validate across API levels.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="database" path="webview" />
        <exclude domain="file" path="webview" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="database" path="webview" />
        <exclude domain="file" path="webview" />
    </device-transfer>
</data-extraction-rules>
