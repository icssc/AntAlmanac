<?xml version="1.0" encoding="utf-8"?>
<!--
  Bubblewrap-generated TWA manifest. The two activities and one service
  below are the standard PWABuilder/Bubblewrap surface — every meta-data
  tag is consumed by `androidbrowserhelper:2.6.0` to configure Chrome's
  Trusted Web Activity shell.

  Placeholders (${hostName}, ${defaultUrl}, etc.) are substituted from
  manifestPlaceholders in app/build.gradle.kts, which Bubblewrap keeps in
  sync with twa-manifest.json.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Geolocation delegation pulls in ACCESS_*_LOCATION transitively from
         androidbrowserhelper:locationdelegation. Declared explicitly so the
         Play Store listing reflects the request. -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- Notification delegation (TWA -> system notifications via the
         DelegationService below) needs POST_NOTIFICATIONS on Android 13+. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.AntAlmanac.Starting"
        tools:targetApi="34">

        <!--
          The launcher activity. Extending `LauncherActivity` from
          androidbrowserhelper is all the application code we have to
          write: it reads the meta-data tags below, launches Chrome as a
          Trusted Web Activity, and draws the splash drawable during the
          Chrome warm-up handshake.
        -->
        <activity
            android:name=".LauncherActivity"
            android:alwaysRetainTaskState="true"
            android:exported="true"
            android:label="${launcherName}">

            <!-- The URL the TWA opens. App Links cause arbitrary
                 antalmanac.com paths to land here, but cold launches
                 still need a default. -->
            <meta-data
                android:name="android.support.customtabs.trusted.DEFAULT_URL"
                android:value="${defaultUrl}" />

            <!-- Colour metadata. Bubblewrap names these after the
                 web-manifest fields they correspond to. -->
            <meta-data
                android:name="android.support.customtabs.trusted.STATUS_BAR_COLOR"
                android:resource="@color/colorPrimary" />
            <meta-data
                android:name="android.support.customtabs.trusted.STATUS_BAR_COLOR_DARK"
                android:resource="@color/colorPrimaryDark" />
            <meta-data
                android:name="android.support.customtabs.trusted.NAVIGATION_BAR_COLOR"
                android:resource="@color/navigationColor" />
            <meta-data
                android:name="android.support.customtabs.trusted.NAVIGATION_BAR_COLOR_DARK"
                android:resource="@color/navigationColorDark" />
            <meta-data
                android:name="androix.browser.trusted.NAVIGATION_BAR_DIVIDER_COLOR"
                android:resource="@color/navigationDividerColor" />
            <meta-data
                android:name="androix.browser.trusted.NAVIGATION_BAR_DIVIDER_COLOR_DARK"
                android:resource="@color/navigationDividerColorDark" />

            <!-- Splash screen shown while Chrome is being warmed up.
                 Drawn entirely by androidbrowserhelper — there's no
                 splash activity of our own. -->
            <meta-data
                android:name="android.support.customtabs.trusted.SPLASH_IMAGE_DRAWABLE"
                android:resource="@drawable/splash" />
            <meta-data
                android:name="android.support.customtabs.trusted.SPLASH_SCREEN_BACKGROUND_COLOR"
                android:resource="@color/backgroundColor" />
            <meta-data
                android:name="android.support.customtabs.trusted.SPLASH_SCREEN_FADE_OUT_DURATION"
                android:value="@integer/splashScreenFadeOutDuration" />
            <meta-data
                android:name="android.support.customtabs.trusted.FILE_PROVIDER_AUTHORITY"
                android:value="${providerAuthority}" />

            <meta-data
                android:name="android.app.shortcuts"
                android:resource="@xml/shortcuts" />

            <!-- What Chrome should do if the host device doesn't have a
                 browser that supports TWA: fall back to Custom Tabs (a
                 visible URL bar) rather than WebView. -->
            <meta-data
                android:name="android.support.customtabs.trusted.FALLBACK_STRATEGY"
                android:value="${fallbackType}" />

            <meta-data
                android:name="android.support.customtabs.trusted.DISPLAY_MODE"
                android:value="${displayMode}" />

            <meta-data
                android:name="android.support.customtabs.trusted.SCREEN_ORIENTATION"
                android:value="${orientation}" />

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!--
              App Links: Chrome's TWA verifier + Android's general
              intent-filter verifier both consult
              https://antalmanac.com/.well-known/assetlinks.json on install.
              If the package + SHA-256 fingerprint match, the URL bar is
              hidden and arbitrary https://antalmanac.com/* links route
              here automatically. Otherwise the TWA falls back to Custom
              Tabs (see FALLBACK_STRATEGY above).
            -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data
                    android:scheme="https"
                    android:host="${hostName}" />
            </intent-filter>
        </activity>

        <!--
          FocusActivity bounces the user back into the running TWA when a
          notification is tapped (the TWA is single-task so we can't
          launch it twice). Lives in the library — we just declare it.
        -->
        <activity
            android:name="com.google.androidbrowserhelper.trusted.FocusActivity"
            android:exported="false" />

        <!--
          WebViewFallbackActivity hosts a WebView fallback for cases
          where neither TWA nor Custom Tabs are available (rare —
          mostly Chrome-stripped corporate devices). Pulled in by the
          library; declared here so the manifest merger doesn't drop it.
        -->
        <activity
            android:name="com.google.androidbrowserhelper.trusted.WebViewFallbackActivity"
            android:configChanges="orientation|screenSize"
            android:exported="false" />

        <!--
          Notification delegation service. The web app's Service Worker
          calls `registration.showNotification(...)` over the Trusted Web
          Activity bridge; Chrome forwards the payload here, which posts
          it through Android's NotificationManager.
        -->
        <service
            android:name=".DelegationService"
            android:enabled="@bool/enableNotification"
            android:exported="true">

            <meta-data
                android:name="android.support.customtabs.trusted.SMALL_ICON"
                android:resource="@drawable/ic_notification_icon" />

            <intent-filter>
                <action
                    android:name="android.support.customtabs.trusted.TRUSTED_WEB_ACTIVITY_SERVICE" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </service>

        <!--
          FileProvider used by androidbrowserhelper's share-target handling
          to expose `content://...` URIs over the Custom Tab IPC. Required
          even if we don't define a share target in twa-manifest.json yet.
        -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${providerAuthority}"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/filepaths" />
        </provider>
    </application>

    <!-- TWA discovery: lets the launcher activity probe whether Chrome /
         another TWA-capable browser is installed before falling back. -->
    <queries>
        <intent>
            <action android:name="android.support.customtabs.action.CustomTabsService" />
        </intent>
    </queries>

</manifest>
