{
    "$schema": "./node_modules/oxlint/configuration_schema.json",
    "plugins": ["eslint", "react", "unicorn", "oxc", "typescript"],
    "rules": {
        "sort-imports": [
            "error",
            {
                "ignoreDeclarationSort": true
            }
        ]
    },
    "globals": {},
    "ignorePatterns": ["node_modules/**", ".next/**", "dist/**", "build/**"]
}
